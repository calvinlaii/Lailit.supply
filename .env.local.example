# Clerk — auth (replaces former Supabase magic-link)
# Get keys from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx           # NEVER NEXT_PUBLIC_ — server-only
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Cloudflare D1 — DB (auth handled by Clerk)
# No env vars needed: D1 is accessed via the `DB` binding configured in wrangler.jsonc.
# Active database: `lailit-db` (already provisioned).
# Setup for fresh checkouts:
#   1. wrangler d1 migrations apply lailit-db --local    # local dev DB
#   2. wrangler d1 migrations apply lailit-db --remote   # production DB
# In code, get the binding via getCloudflareContext().env.DB (see src/lib/db/index.ts).

# App URL — used by Clerk redirects in production
# Local dev: http://localhost:3000
# Production: https://lailit.supply
NEXT_PUBLIC_SITE_URL=https://lailit.supply

# ─── Phase 4: Payments & Webhooks ───────────────────────────────────────────

# Mayar.id — checkout links (public, safe for client-side)
NEXT_PUBLIC_MAYAR_MONTHLY_URL=https://mayar.id/checkout/...
NEXT_PUBLIC_MAYAR_LIFETIME_URL=https://mayar.id/checkout/...

# Mayar.id — server-side secrets (NEVER prefix with NEXT_PUBLIC_)
MAYAR_API_KEY=                    # From web.mayar.id → API → Generate Key
MAYAR_WEBHOOK_TOKEN=              # Random secret: openssl rand -hex 32
MAYAR_CUSTOMER_PORTAL_URL=        # From Mayar Dashboard → Customer Portal

# Resend — email delivery
RESEND_API_KEY=                   # From resend.com → Dashboard → API Keys
